---
import "../styles/global.css";

interface Props {
  title?: string;
}
const { title = "NOISE — 生態距離練習 / Practicing Ecological Distance" } = Astro.props;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="NOISE 將公共資料流轉成多軌聲景，讓地震、天氣、空污與城市基礎設施一起發聲。 / NOISE turns public data streams into a multi-track spatial score."
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
