---
// All audio + API logic runs client-side
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NOISE — Seismic Bass</title>
    <style>
      :root {
        --bg: #0a0a0a;
        --surface: #111;
        --border: #222;
        --accent: #ff3c1f;
        --accent2: #ff8c42;
        --text: #e8e8e8;
        --muted: #555;
        --green: #39ff14;
        --mono: "Courier New", Courier, monospace;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--mono);
        min-height: 100vh;
        display: grid;
        grid-template-rows: auto 1fr;
      }

      /* ── Header ── */
      header {
        border-bottom: 1px solid var(--border);
        padding: 1.25rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .logo {
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: 0.25em;
        color: var(--accent);
        text-transform: uppercase;
      }

      .logo span {
        color: var(--text);
      }

      .status-pill {
        font-size: 0.7rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        padding: 0.3rem 0.75rem;
        border-radius: 999px;
        border: 1px solid var(--muted);
        color: var(--muted);
      }

      .status-pill.live {
        border-color: var(--green);
        color: var(--green);
        box-shadow: 0 0 8px rgba(57, 255, 20, 0.3);
      }

      /* ── Main Layout ── */
      main {
        display: grid;
        grid-template-columns: 1fr 360px;
        grid-template-rows: auto 1fr;
        gap: 0;
        overflow: hidden;
        height: calc(100vh - 65px);
      }

      /* ── Visualizer ── */
      #viz-panel {
        grid-column: 1;
        grid-row: 1;
        border-bottom: 1px solid var(--border);
        border-right: 1px solid var(--border);
        padding: 1.5rem 2rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .viz-label {
        font-size: 0.65rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--muted);
      }

      canvas {
        width: 100%;
        height: 120px;
        display: block;
        background: #050505;
        border: 1px solid var(--border);
        border-radius: 3px;
      }

      /* ── Controls ── */
      #controls-panel {
        grid-column: 1;
        grid-row: 2;
        border-right: 1px solid var(--border);
        padding: 1.25rem 2rem;
        display: flex;
        align-items: flex-start;
        gap: 1.5rem;
        flex-wrap: wrap;
        align-content: flex-start;
      }

      .control-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .control-label {
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .btn {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text);
        font-family: var(--mono);
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.5rem 1rem;
        cursor: pointer;
        transition: all 0.15s;
        border-radius: 3px;
      }

      .btn:hover {
        border-color: var(--accent);
        color: var(--accent);
      }

      .btn.active {
        background: var(--accent);
        border-color: var(--accent);
        color: #fff;
        box-shadow: 0 0 14px rgba(255, 60, 31, 0.4);
      }

      .btn-row {
        display: flex;
        gap: 0.5rem;
      }

      input[type="range"] {
        -webkit-appearance: none;
        width: 140px;
        height: 3px;
        background: var(--border);
        border-radius: 999px;
        outline: none;
      }

      input[type="range"]::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 14px;
        height: 14px;
        background: var(--accent);
        border-radius: 50%;
        cursor: pointer;
        box-shadow: 0 0 6px rgba(255, 60, 31, 0.5);
      }

      .range-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .range-val {
        font-size: 0.7rem;
        color: var(--accent2);
        min-width: 3ch;
        text-align: right;
      }

      /* ── Sidebar: Quake List ── */
      #list-panel {
        grid-column: 2;
        grid-row: 1 / 3;
        overflow-y: auto;
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      #list-panel::-webkit-scrollbar {
        width: 4px;
      }
      #list-panel::-webkit-scrollbar-track {
        background: transparent;
      }
      #list-panel::-webkit-scrollbar-thumb {
        background: var(--border);
        border-radius: 999px;
      }

      .list-header {
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--muted);
        padding: 0.25rem 0.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .quake-card {
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 0.75rem;
        cursor: pointer;
        transition: all 0.15s;
        background: var(--surface);
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.5rem 0.75rem;
        align-items: start;
      }

      .quake-card:hover {
        border-color: var(--accent2);
        background: #161616;
      }

      .quake-card.playing {
        border-color: var(--accent);
        background: #1a0800;
        box-shadow: 0 0 12px rgba(255, 60, 31, 0.2);
      }

      .mag-badge {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--accent);
        line-height: 1;
        padding-top: 2px;
      }

      .mag-badge.low {
        color: var(--green);
      }
      .mag-badge.mid {
        color: var(--accent2);
      }
      .mag-badge.high {
        color: var(--accent);
      }

      .quake-info {
        display: flex;
        flex-direction: column;
        gap: 3px;
      }

      .quake-place {
        font-size: 0.72rem;
        color: var(--text);
        line-height: 1.3;
      }

      .quake-meta {
        font-size: 0.6rem;
        color: var(--muted);
        display: flex;
        gap: 0.5rem;
      }

      .quake-freq {
        font-size: 0.6rem;
        color: var(--accent2);
      }

      /* ── Empty / Loading ── */
      .loading {
        color: var(--muted);
        font-size: 0.8rem;
        text-align: center;
        padding: 2rem;
        letter-spacing: 0.1em;
      }

      /* ── Info box ── */
      .info-box {
        grid-column: 1;
        border-top: 1px solid var(--border);
        padding: 0.75rem 2rem;
        font-size: 0.65rem;
        color: var(--muted);
        letter-spacing: 0.05em;
        line-height: 1.6;
      }

      .info-box b {
        color: var(--accent2);
      }

      /* ── Currently playing ── */
      #now-playing {
        font-size: 0.7rem;
        color: var(--accent2);
        letter-spacing: 0.05em;
        min-height: 1.2em;
      }

      @media (max-width: 768px) {
        main {
          grid-template-columns: 1fr;
          grid-template-rows: auto auto 1fr;
          height: auto;
        }
        #list-panel {
          grid-column: 1;
          grid-row: 3;
          height: 50vh;
        }
        #controls-panel {
          grid-row: 2;
          border-right: none;
          border-bottom: 1px solid var(--border);
        }
        #viz-panel {
          border-right: none;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="logo">NOISE<span> / seismic bass</span></div>
      <div style="display:flex; gap:0.75rem; align-items:center;">
        <div id="status-pill" class="status-pill">loading</div>
        <button class="btn" id="refresh-btn">↺ refresh</button>
      </div>
    </header>

    <main>
      <!-- Visualizer -->
      <section id="viz-panel">
        <div class="viz-label">oscilloscope</div>
        <canvas id="osc-canvas" width="900" height="120"></canvas>

        <div class="viz-label" style="margin-top:0.25rem;">
          frequency spectrum (sub-bass)
        </div>
        <canvas id="freq-canvas" width="900" height="80"></canvas>

        <div id="now-playing">— select an earthquake or press play —</div>
      </section>

      <!-- Controls -->
      <section id="controls-panel">
        <div class="control-group">
          <div class="control-label">sequencer</div>
          <div class="btn-row">
            <button class="btn" id="play-btn">▶ play</button>
            <button class="btn" id="stop-btn">■ stop</button>
          </div>
        </div>

        <div class="control-group">
          <div class="control-label">master volume</div>
          <div class="range-row">
            <input
              type="range"
              id="vol-slider"
              min="0"
              max="1"
              step="0.01"
              value="0.7"
            />
            <span class="range-val" id="vol-val">70%</span>
          </div>
        </div>

        <div class="control-group">
          <div class="control-label">note duration (ms)</div>
          <div class="range-row">
            <input
              type="range"
              id="dur-slider"
              min="500"
              max="8000"
              step="100"
              value="2500"
            />
            <span class="range-val" id="dur-val">2500</span>
          </div>
        </div>

        <div class="control-group">
          <div class="control-label">reverb mix</div>
          <div class="range-row">
            <input
              type="range"
              id="rev-slider"
              min="0"
              max="1"
              step="0.01"
              value="0.4"
            />
            <span class="range-val" id="rev-val">40%</span>
          </div>
        </div>

        <div class="control-group">
          <div class="control-label">lfo rate (hz)</div>
          <div class="range-row">
            <input
              type="range"
              id="lfo-slider"
              min="0.05"
              max="3"
              step="0.05"
              value="0.3"
            />
            <span class="range-val" id="lfo-val">0.30</span>
          </div>
        </div>

        <div class="control-group">
          <div class="control-label">waveform</div>
          <div class="btn-row" id="wave-btns">
            <button class="btn active" data-wave="sine">sine</button>
            <button class="btn" data-wave="triangle">tri</button>
            <button class="btn" data-wave="sawtooth">saw</button>
            <button class="btn" data-wave="square">sqr</button>
          </div>
        </div>
      </section>

      <!-- Quake List -->
      <aside id="list-panel">
        <div class="list-header">
          <span>recent earthquakes (usgs)</span>
          <span id="quake-count">—</span>
        </div>
        <div id="quake-list" class="loading">fetching seismic data…</div>
      </aside>
    </main>

    <script>
      // ══════════════════════════════════════════════
      //  AUDIO ENGINE
      // ══════════════════════════════════════════════

      let audioCtx: AudioContext | null = null;
      let masterGain: GainNode;
      let analyser: AnalyserNode;
      let reverbNode: ConvolverNode;
      let reverbGain: GainNode;
      let dryGain: GainNode;

      function ensureAudio() {
        if (audioCtx) return;
        audioCtx = new AudioContext();

        masterGain = audioCtx.createGain();
        masterGain.gain.value = 0.7;

        analyser = audioCtx.createAnalyser();
        analyser.fftSize = 2048;
        analyser.smoothingTimeConstant = 0.85;

        dryGain = audioCtx.createGain();
        dryGain.gain.value = 0.6;

        reverbGain = audioCtx.createGain();
        reverbGain.gain.value = 0.4;

        reverbNode = audioCtx.createConvolver();
        reverbNode.buffer = buildImpulse(audioCtx, 3.5, 3.0);

        // routing: masterGain → dry → analyser → destination
        //          masterGain → reverb → reverbGain → analyser → destination
        masterGain.connect(dryGain);
        masterGain.connect(reverbNode);
        dryGain.connect(analyser);
        reverbNode.connect(reverbGain);
        reverbGain.connect(analyser);
        analyser.connect(audioCtx.destination);
      }

      function buildImpulse(
        ctx: AudioContext,
        duration: number,
        decay: number,
      ): AudioBuffer {
        const sr = ctx.sampleRate;
        const len = Math.floor(sr * duration);
        const buf = ctx.createBuffer(2, len, sr);
        for (let ch = 0; ch < 2; ch++) {
          const data = buf.getChannelData(ch);
          for (let i = 0; i < len; i++) {
            data[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / len, decay);
          }
        }
        return buf;
      }

      function magToFreq(mag: number): number {
        // Map magnitude 0–10 → 20–220 Hz (pure bass range)
        const clamped = Math.max(0, Math.min(10, mag));
        return 20 + (clamped / 10) * 200;
      }

      function depthToWave(depth: number): OscillatorType {
        const w = (
          document.querySelector("#wave-btns .btn.active") as HTMLButtonElement
        )?.dataset.wave as OscillatorType;
        return w ?? "sine";
      }

      interface PlayOptions {
        frequency: number;
        waveform: OscillatorType;
        duration: number;
        lfoRate: number;
      }

      function playBass({
        frequency,
        waveform,
        duration,
        lfoRate,
      }: PlayOptions) {
        if (!audioCtx) return;

        const now = audioCtx.currentTime;
        const attack = 0.12;
        const release = Math.min(1.8, duration * 0.0004);
        const sustain = duration / 1000 - attack - release;

        // ── Oscillator
        const osc = audioCtx.createOscillator();
        osc.type = waveform;
        osc.frequency.setValueAtTime(frequency, now);

        // ── LFO (pitch wobble)
        const lfo = audioCtx.createOscillator();
        const lfoGain = audioCtx.createGain();
        lfo.frequency.value = lfoRate;
        lfoGain.gain.value = frequency * 0.015; // ±1.5% pitch drift
        lfo.connect(lfoGain);
        lfoGain.connect(osc.frequency);
        lfo.start(now);
        lfo.stop(now + duration / 1000 + 0.1);

        // ── Envelope
        const env = audioCtx.createGain();
        env.gain.setValueAtTime(0, now);
        env.gain.linearRampToValueAtTime(1.0, now + attack);
        env.gain.setValueAtTime(1.0, now + attack + Math.max(0, sustain));
        env.gain.linearRampToValueAtTime(
          0,
          now + attack + Math.max(0, sustain) + release,
        );

        // ── Low-pass filter (keep it bassy)
        const lpf = audioCtx.createBiquadFilter();
        lpf.type = "lowpass";
        lpf.frequency.value = 280;
        lpf.Q.value = 1.2;

        // ── Chain
        osc.connect(lpf);
        lpf.connect(env);
        env.connect(masterGain);

        osc.start(now);
        osc.stop(now + duration / 1000 + 0.5);

        return osc;
      }

      // ══════════════════════════════════════════════
      //  VISUALIZER
      // ══════════════════════════════════════════════

      const oscCanvas = document.getElementById(
        "osc-canvas",
      ) as HTMLCanvasElement;
      const freqCanvas = document.getElementById(
        "freq-canvas",
      ) as HTMLCanvasElement;
      const oscCtx = oscCanvas.getContext("2d")!;
      const freqCtxC = freqCanvas.getContext("2d")!;

      function drawViz() {
        requestAnimationFrame(drawViz);
        if (!analyser) {
          clearCanvas(oscCtx, oscCanvas);
          clearCanvas(freqCtxC, freqCanvas);
          return;
        }

        const bufLen = analyser.frequencyBinCount;
        const timeData = new Float32Array(bufLen);
        const freqData = new Uint8Array(bufLen);
        analyser.getFloatTimeDomainData(timeData);
        analyser.getByteFrequencyData(freqData);

        // Oscilloscope
        const w1 = oscCanvas.width,
          h1 = oscCanvas.height;
        oscCtx.fillStyle = "#050505";
        oscCtx.fillRect(0, 0, w1, h1);
        oscCtx.strokeStyle = "#ff3c1f";
        oscCtx.lineWidth = 1.5;
        oscCtx.shadowColor = "#ff3c1f";
        oscCtx.shadowBlur = 4;
        oscCtx.beginPath();
        const sliceW = w1 / bufLen;
        let x = 0;
        for (let i = 0; i < bufLen; i++) {
          const v = timeData[i];
          const y = ((v + 1) / 2) * h1;
          i === 0 ? oscCtx.moveTo(x, y) : oscCtx.lineTo(x, y);
          x += sliceW;
        }
        oscCtx.stroke();
        oscCtx.shadowBlur = 0;

        // Frequency bars — show only sub-bass bins (0–300 Hz)
        const w2 = freqCanvas.width,
          h2 = freqCanvas.height;
        freqCtxC.fillStyle = "#050505";
        freqCtxC.fillRect(0, 0, w2, h2);

        if (audioCtx) {
          const nyquist = audioCtx.sampleRate / 2;
          const maxFreq = 300; // Hz
          const maxBin = Math.floor((maxFreq / nyquist) * bufLen);
          const barW = w2 / maxBin;

          for (let i = 0; i < maxBin; i++) {
            const bh = (freqData[i] / 255) * h2;
            const hue = 15 + (i / maxBin) * 25;
            freqCtxC.fillStyle = `hsl(${hue}, 100%, 55%)`;
            freqCtxC.fillRect(i * barW, h2 - bh, barW - 1, bh);
          }
        }
      }

      function clearCanvas(
        ctx: CanvasRenderingContext2D,
        canvas: HTMLCanvasElement,
      ) {
        ctx.fillStyle = "#050505";
        ctx.fillRect(0, 0, canvas.width, canvas.height);
      }

      drawViz();

      // ══════════════════════════════════════════════
      //  EARTHQUAKE DATA
      // ══════════════════════════════════════════════

      interface Quake {
        id: string;
        mag: number;
        place: string;
        depth: number;
        time: number;
        freq: number;
      }

      let quakes: Quake[] = [];
      let playingId: string | null = null;
      let sequenceTimer: ReturnType<typeof setTimeout> | null = null;
      let sequenceIndex = 0;
      let isSequencing = false;

      async function fetchQuakes() {
        const statusPill = document.getElementById("status-pill")!;
        statusPill.textContent = "loading";
        statusPill.className = "status-pill";

        try {
          // last day, all magnitudes
          const res = await fetch(
            "https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_day.geojson",
          );
          const json = await res.json();

          quakes = json.features
            .filter((f: any) => f.properties.mag !== null)
            .sort((a: any, b: any) => b.properties.mag - a.properties.mag)
            .slice(0, 80)
            .map((f: any) => ({
              id: f.id,
              mag: f.properties.mag,
              place: f.properties.place ?? "Unknown location",
              depth: f.geometry.coordinates[2],
              time: f.properties.time,
              freq: magToFreq(f.properties.mag),
            }));

          renderList();
          statusPill.textContent = "live";
          statusPill.className = "status-pill live";
          document.getElementById("quake-count")!.textContent =
            `${quakes.length} events`;
        } catch (e) {
          console.error(e);
          statusPill.textContent = "error";
          document.getElementById("quake-list")!.innerHTML =
            '<div class="loading">failed to fetch — check console</div>';
        }
      }

      function formatTime(ts: number): string {
        return (
          new Date(ts).toISOString().replace("T", " ").slice(0, 16) + " UTC"
        );
      }

      function magClass(mag: number): string {
        if (mag < 2.5) return "low";
        if (mag < 5) return "mid";
        return "high";
      }

      function renderList() {
        const container = document.getElementById("quake-list")!;
        container.innerHTML = "";
        container.className = "";

        for (const q of quakes) {
          const card = document.createElement("div");
          card.className = "quake-card";
          card.dataset.id = q.id;
          if (q.id === playingId) card.classList.add("playing");

          card.innerHTML = `
      <div class="mag-badge ${magClass(q.mag)}">${q.mag.toFixed(1)}</div>
      <div class="quake-info">
        <div class="quake-place">${q.place}</div>
        <div class="quake-meta">
          <span>depth ${q.depth.toFixed(1)} km</span>
          <span>${formatTime(q.time)}</span>
        </div>
        <div class="quake-freq">♩ ${q.freq.toFixed(1)} Hz</div>
      </div>
    `;

          card.addEventListener("click", () => {
            stopSequence();
            triggerQuake(q);
          });

          container.appendChild(card);
        }
      }

      function triggerQuake(q: Quake) {
        ensureAudio();
        if (audioCtx?.state === "suspended") audioCtx.resume();

        // Update UI
        playingId = q.id;
        document.querySelectorAll(".quake-card").forEach((c) => {
          c.classList.toggle("playing", (c as HTMLElement).dataset.id === q.id);
        });

        const dur = parseInt(
          (document.getElementById("dur-slider") as HTMLInputElement).value,
        );
        const lfoRate = parseFloat(
          (document.getElementById("lfo-slider") as HTMLInputElement).value,
        );

        document.getElementById("now-playing")!.textContent =
          `▶ M${q.mag.toFixed(1)}  ${q.freq.toFixed(1)} Hz  —  ${q.place}`;

        playBass({
          frequency: q.freq,
          waveform: depthToWave(q.depth),
          duration: dur,
          lfoRate,
        });
      }

      // ══════════════════════════════════════════════
      //  SEQUENCER
      // ══════════════════════════════════════════════

      function startSequence() {
        if (!quakes.length) return;
        isSequencing = true;
        sequenceIndex = 0;
        document.getElementById("play-btn")!.classList.add("active");
        stepSequence();
      }

      function stepSequence() {
        if (!isSequencing || sequenceIndex >= quakes.length) {
          stopSequence();
          return;
        }
        triggerQuake(quakes[sequenceIndex]);
        const dur = parseInt(
          (document.getElementById("dur-slider") as HTMLInputElement).value,
        );
        sequenceIndex++;
        sequenceTimer = setTimeout(stepSequence, dur + 200);
      }

      function stopSequence() {
        isSequencing = false;
        if (sequenceTimer) clearTimeout(sequenceTimer);
        sequenceTimer = null;
        document.getElementById("play-btn")!.classList.remove("active");
        document.getElementById("now-playing")!.textContent = "— stopped —";
        document
          .querySelectorAll(".quake-card")
          .forEach((c) => c.classList.remove("playing"));
        playingId = null;
      }

      // ══════════════════════════════════════════════
      //  CONTROLS WIRING
      // ══════════════════════════════════════════════

      document.getElementById("play-btn")!.addEventListener("click", () => {
        ensureAudio();
        if (audioCtx?.state === "suspended") audioCtx.resume();
        isSequencing ? stopSequence() : startSequence();
      });

      document
        .getElementById("stop-btn")!
        .addEventListener("click", stopSequence);
      document
        .getElementById("refresh-btn")!
        .addEventListener("click", fetchQuakes);

      // Volume
      const volSlider = document.getElementById(
        "vol-slider",
      ) as HTMLInputElement;
      const volVal = document.getElementById("vol-val")!;
      volSlider.addEventListener("input", () => {
        const v = parseFloat(volSlider.value);
        volVal.textContent = `${Math.round(v * 100)}%`;
        if (masterGain) masterGain.gain.value = v;
      });

      // Duration
      const durSlider = document.getElementById(
        "dur-slider",
      ) as HTMLInputElement;
      const durVal = document.getElementById("dur-val")!;
      durSlider.addEventListener("input", () => {
        durVal.textContent = durSlider.value;
      });

      // Reverb
      const revSlider = document.getElementById(
        "rev-slider",
      ) as HTMLInputElement;
      const revVal = document.getElementById("rev-val")!;
      revSlider.addEventListener("input", () => {
        const v = parseFloat(revSlider.value);
        revVal.textContent = `${Math.round(v * 100)}%`;
        if (reverbGain) {
          reverbGain.gain.value = v;
          dryGain.gain.value = 1 - v * 0.4;
        }
      });

      // LFO
      const lfoSlider = document.getElementById(
        "lfo-slider",
      ) as HTMLInputElement;
      const lfoVal = document.getElementById("lfo-val")!;
      lfoSlider.addEventListener("input", () => {
        lfoVal.textContent = parseFloat(lfoSlider.value).toFixed(2);
      });

      // Waveform buttons
      document.querySelectorAll("#wave-btns .btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          document
            .querySelectorAll("#wave-btns .btn")
            .forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
        });
      });

      // ══════════════════════════════════════════════
      //  INIT
      // ══════════════════════════════════════════════

      fetchQuakes();
    </script>
  </body>
</html>
