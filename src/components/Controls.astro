---

---

<section id="controls-panel">
  <div class="control-group">
    <div class="control-label">sequencer</div>
    <div class="btn-row">
      <button class="btn" id="play-btn">▶ play</button>
      <button class="btn" id="stop-btn">■ stop</button>
    </div>
  </div>

  <div class="control-group">
    <div class="control-label">master volume</div>
    <div class="range-row">
      <input
        type="range"
        id="vol-slider"
        min="0"
        max="1"
        step="0.01"
        value="0.7"
      />
      <span class="range-val" id="vol-val">70%</span>
    </div>
  </div>

  <div class="control-group">
    <div class="control-label">note duration (ms)</div>
    <div class="range-row">
      <input
        type="range"
        id="dur-slider"
        min="500"
        max="8000"
        step="100"
        value="2500"
      />
      <span class="range-val" id="dur-val">2500</span>
    </div>
  </div>

  <div class="control-group">
    <div class="control-label">reverb mix</div>
    <div class="range-row">
      <input
        type="range"
        id="rev-slider"
        min="0"
        max="1"
        step="0.01"
        value="0.4"
      />
      <span class="range-val" id="rev-val">40%</span>
    </div>
  </div>

  <div class="control-group">
    <div class="control-label">lfo rate (hz)</div>
    <div class="range-row">
      <input
        type="range"
        id="lfo-slider"
        min="0.05"
        max="3"
        step="0.05"
        value="0.3"
      />
      <span class="range-val" id="lfo-val">0.30</span>
    </div>
  </div>

  <div class="control-group">
    <div class="control-label">waveform</div>
    <div class="btn-row" id="wave-btns">
      <button class="btn active" data-wave="sine">sine</button>
      <button class="btn" data-wave="triangle">tri</button>
      <button class="btn" data-wave="sawtooth">saw</button>
      <button class="btn" data-wave="square">sqr</button>
    </div>
  </div>
</section>
